{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://json-to-google-form.dev/schema/form.v1.schema.json",
  "title": "Form DSL v1",
  "type": "object",
  "required": ["title", "sections"],
  "additionalProperties": false,
  "properties": {
    "title": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "sections": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["title", "items"],
        "additionalProperties": false,
        "properties": {
          "title": {
            "type": "string",
            "minLength": 1
          },
          "items": {
            "type": "array"
          }
        }
      }
    }
  }
}
