{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://json-to-google-form.dev/schema/form.v1.schema.json",
  "title": "Form DSL v1",
  "type": "object",
  "required": ["id", "title", "description", "mode", "settings", "pages"],
  "additionalProperties": false,
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "title": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "mode": { "type": "string", "enum": ["form", "quiz"] },
    "settings": {
      "type": "object",
      "required": ["collectEmails", "limitOneResponse", "shuffleQuestions"],
      "additionalProperties": false,
      "properties": {
        "collectEmails": { "type": "boolean" },
        "limitOneResponse": { "type": "boolean" },
        "shuffleQuestions": { "type": "boolean" }
      }
    },
    "pages": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "title", "questions"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "title": { "type": "string", "minLength": 1 },
          "questions": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["id", "type", "title", "required"],
              "additionalProperties": false,
              "properties": {
                "id": { "type": "string", "minLength": 1 },
                "type": {
                  "type": "string",
                  "enum": ["text", "multiple_choice", "checkbox", "dropdown", "true_false", "short_answer"]
                },
                "title": { "type": "string", "minLength": 1 },
                "required": { "type": "boolean" },
                "options": {
                  "type": "array",
                  "items": { "type": "string" },
                  "minItems": 1
                },
                "correctAnswer": { "type": "string" },
                "score": { "type": "number", "minimum": 0 },
                "media": {
                  "type": "object",
                  "required": ["type", "url"],
                  "additionalProperties": false,
                  "properties": {
                    "type": { "type": "string", "enum": ["image", "video", "audio"] },
                    "url": { "type": "string", "format": "uri" }
                  }
                },
                "metadata": {
                  "type": "object",
                  "additionalProperties": false,
                  "properties": {
                    "topic": { "type": "string" },
                    "difficulty": { "type": "string", "enum": ["easy", "medium", "hard"] }
                  }
                }
              },
              "if": {
                "properties": { "type": { "enum": ["multiple_choice", "checkbox", "dropdown"] } }
              },
              "then": {
                "required": ["options"]
              }
            }
          }
        }
      }
    }
  }
}
